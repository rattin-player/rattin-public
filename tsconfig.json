{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "jsx": "react-jsx",
    "types": ["node"],
    "allowJs": false,
    "noEmit": true
  },
  "include": ["lib/**/*", "routes/**/*", "server.*", "test/**/*"],
  "exclude": ["node_modules", "dist", "public", "src", "test/appimage"]
}
