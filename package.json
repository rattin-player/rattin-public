{
  "name": "rattin",
  "version": "2.0.0",
  "description": "",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "tsx --env-file=.env server.ts",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:exe": "pkg . --targets node20-win-x64 --output dist/rattin.exe --options max-old-space-size=4096",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test test/*.test.js test/lib/*.test.js test/routes/*.test.js"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "node_modules/node-datachannel/build/**/*"
    ],
    "outputPath": "dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "uqr": "^0.1.2",
    "webtorrent": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-react": "^4.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^6.3.5"
  }
}
